# Optional overrides loaded by ygg-shift-prune.service

# Keep this many shift-* snapshots per mapped dataset on local and remote sides.
SHIFT_PRUNE_KEEP_LOCAL=48
SHIFT_PRUNE_KEEP_REMOTE=48

# 1 to prune, 0 to skip side
SHIFT_PRUNE_LOCAL=1
SHIFT_PRUNE_REMOTE=1

# Set to 1 for dry-run preview
SHIFT_DRY_RUN=0
