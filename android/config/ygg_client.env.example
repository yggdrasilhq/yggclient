# Optional runtime policy for Android Termux yggsync wrappers.
# Copy to ~/.config/ygg_client.env if you want persistent policy overrides.

# Require Wi-Fi before starting or continuing a run.
YGG_REQUIRE_WIFI=1

# Minimum battery percentages when not charging.
YGG_MIN_BATTERY_FAST=50
YGG_MIN_BATTERY_BULK=65

# Battery temperature ceilings in Celsius.
YGG_MAX_BATTERY_TEMP_FAST_C=39.5
YGG_MAX_BATTERY_TEMP_BULK_C=38.5

# How often the wrappers re-check heat/network conditions during a run.
YGG_MONITOR_INTERVAL_SECONDS=20

# SMB connectivity check timeout in seconds.
YGG_HOST_CHECK_TIMEOUT_SECONDS=3

# Tailscale binary name or full path if installed.
YGG_TAILSCALE_BIN=tailscale
