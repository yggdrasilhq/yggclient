# Copy to config/profiles.local.env (gitignored) and customize.

# Shift-sync defaults
SHIFT_REMOTE=root@build-host.example
SHIFT_IDENTITY=client-a
SHIFT_SOURCE_ROOT=zroot/ROOT/debian
SHIFT_REMOTE_ROOT=zroot/lxc/client-a/ROOT/debian

# Optional yggsync rendering defaults
SAMBA_HOST=nas.lan
SAMBA_SHARE=data
SAMBA_USER=alice
SAMBA_USERNAME=alice
SAMBA_PASSWORD_ENV=SAMBA_PASSWORD
SCREENCASTS_REMOTE=immich02/alice/desktop/Screencasts

# Optional cert automation defaults
PUBLIC_DOMAIN=example.com
SECRETS_API_URL=https://secrets.example

# Optional shell/CLI defaults for Infisical helpers
INFISICAL_API_URL=https://secrets.example
INFISICAL_PROJECT_ID=replace-with-project-id
INFISICAL_TOKEN=replace-with-machine-token
INFISICAL_INFRA_PROJECT_ID=replace-with-infra-project-id
INFISICAL_INFRA_TOKEN=replace-with-infra-machine-token
