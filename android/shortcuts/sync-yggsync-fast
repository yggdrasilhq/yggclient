#!/data/data/com.termux/files/usr/bin/bash

# Manual trigger for the guarded yggsync fast job wrapper.
SCRIPT_DIR_SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YGG_CLIENT_DIR_DEFAULT="$(cd "$SCRIPT_DIR_SELF/../.." && pwd)"
YGG_CLIENT_DIR="${YGG_CLIENT_DIR:-$YGG_CLIENT_DIR_DEFAULT}"
RUNNER="$YGG_CLIENT_DIR/android/scripts/sync-yggsync-fast.sh"

termux-toast "yggsync fast: obsidian"
"$RUNNER"
status=$?
if [ $status -eq 0 ]; then
  termux-toast "yggsync fast done"
elif [ $status -eq 75 ]; then
  termux-toast -b yellow -c black "yggsync fast deferred"
else
  termux-toast -b red -c white "yggsync fast failed ($status)"
fi
