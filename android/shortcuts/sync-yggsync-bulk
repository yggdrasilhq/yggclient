#!/data/data/com.termux/files/usr/bin/bash

# Manual trigger for the guarded yggsync bulk wrapper.
SCRIPT_DIR_SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YGG_CLIENT_DIR_DEFAULT="$(cd "$SCRIPT_DIR_SELF/../.." && pwd)"
YGG_CLIENT_DIR="${YGG_CLIENT_DIR:-$YGG_CLIENT_DIR_DEFAULT}"
RUNNER="$YGG_CLIENT_DIR/android/scripts/sync-yggsync-bulk.sh"
JOBS="${JOBS:-whatsapp-backups,whatsapp-media,dcim,screenshots,cubecallacr,androidfs}"

termux-toast "yggsync bulk: $JOBS"
JOBS="$JOBS" "$RUNNER"
status=$?
if [ $status -eq 0 ]; then
  termux-toast "yggsync bulk done"
elif [ $status -eq 75 ]; then
  termux-toast -b yellow -c black "yggsync bulk deferred"
else
  termux-toast -b red -c white "yggsync bulk failed ($status)"
fi
