#!/data/data/com.termux/files/usr/bin/bash

# Manual Obsidian sync via the guarded fast wrapper.
SCRIPT_DIR_SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YGG_CLIENT_DIR_DEFAULT="$(cd "$SCRIPT_DIR_SELF/../.." && pwd)"
YGG_CLIENT_DIR="${YGG_CLIENT_DIR:-$YGG_CLIENT_DIR_DEFAULT}"
RUNNER="$YGG_CLIENT_DIR/android/scripts/sync-yggsync-fast.sh"
JOBS="${JOBS:-obsidian,notes}"

termux-toast "Starting yggsync: obsidian"
JOBS="$JOBS" "$RUNNER"
status=$?

if [ $status -eq 0 ]; then
  termux-toast "Obsidian sync done"
elif [ $status -eq 75 ]; then
  termux-toast -b yellow -c black "Obsidian sync deferred"
else
  termux-toast -b red -c white "Obsidian sync failed"
fi

exit 0
